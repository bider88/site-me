---
import { experience } from "../../data/experience";
import { getLangFromUrl } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
---

<section id="experience" class="py-24 px-6 bg-zinc-50/50 dark:bg-zinc-900/20">
  <div class="max-w-3xl mx-auto">
    <h2
      class="text-3xl font-bold text-zinc-900 dark:text-white mb-12 flex items-center gap-3"
    >
      <span class="h-8 w-1 bg-indigo-500 rounded-full"></span>
      {lang === "es" ? "Trayectoria" : "Experience"}
    </h2>

    <div
      class="space-y-12 border-l-2 border-zinc-200 dark:border-zinc-800 ml-4"
    >
      {
        experience.map((exp) => (
          <div class="relative pl-8">
            <div
              class={`absolute -left-[9px] top-1.5 h-4 w-4 rounded-full border-2 border-white dark:border-zinc-950 ${exp.current ? "bg-indigo-500" : "bg-zinc-300 dark:bg-zinc-700"}`}
            />

            <span class="text-sm font-medium text-indigo-600 dark:text-indigo-400">
              {exp.period}
            </span>
            <h3 class="text-xl font-bold text-zinc-900 dark:text-white mt-1">
              {exp.role[lang]}
            </h3>
            <p class="text-zinc-500 dark:text-zinc-400 font-medium">
              {exp.company}
            </p>
            <p class="mt-3 text-zinc-600 dark:text-zinc-400 leading-relaxed">
              {exp.description[lang]}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
