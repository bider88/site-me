---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  class="relative py-20 px-6 sm:py-32 flex flex-col items-center text-center"
>
  <div
    class="mb-6 flex items-center gap-2 rounded-full bg-emerald-500/10 px-3 py-1 text-sm font-medium text-emerald-600 dark:text-emerald-400 border border-emerald-500/20"
  >
    <span class="relative flex h-2 w-2">
      <span
        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
      ></span>
      <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
      ></span>
    </span>
    {lang === "es" ? "Disponible para nuevos proyectos" : "Available for work"}
  </div>

  <h1
    class="max-w-4xl text-4xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-6xl lg:text-7xl"
  >
    {t("hero.title")}
    <span
      class="text-transparent bg-clip-text bg-linear-to-r from-indigo-500 to-cyan-400"
      >{lang === "es" ? "Especialista en UI/UX" : "UI/UX Specialist"}</span
    >
  </h1>

  <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-600 dark:text-zinc-400">
    {
      lang === "es"
        ? "Creando interfaces modernas y experiencias de usuario excepcionales con Angular, React, Astro y las últimas tecnologías web."
        : "Crafting modern interfaces and exceptional user experiences with Angular, React, Astro, and the latest web technologies."
    }
  </p>

  <div class="mt-10 flex flex-wrap items-center justify-center gap-6">
    <a
      href="#projects"
      class="rounded-xl bg-zinc-900 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-zinc-700 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200 transition-all"
    >
      {lang === "es" ? "Ver Proyectos" : "View Projects"}
    </a>
    <a
      href="https://linkedin.com"
      target="_blank"
      class="text-sm font-semibold leading-6 text-zinc-900 dark:text-zinc-100 hover:text-indigo-500 dark:hover:text-indigo-400 transition-colors"
    >
      LinkedIn <span aria-hidden="true">→</span>
    </a>
  </div>
</section>
