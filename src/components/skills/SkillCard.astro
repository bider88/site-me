---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<div
  class="group relative flex items-center gap-3 rounded-xl border border-zinc-200 bg-white p-4 transition-all hover:border-indigo-500/50 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900/50 dark:hover:border-indigo-500/50"
>
  <div
    class="flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-100 text-zinc-900 transition-colors group-hover:bg-indigo-500 group-hover:text-white dark:bg-zinc-800 dark:text-zinc-100 dark:group-hover:bg-indigo-500 dark:group-hover:text-zinc-900"
  >
    <slot name="icon" />
  </div>
  <span class="text-sm font-medium text-zinc-700 dark:text-zinc-300"
    >{name}</span
  >
</div>
