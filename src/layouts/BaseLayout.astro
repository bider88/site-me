---
import "../styles/tailwind.css";
import Nav from "../components/Nav.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import LanguagePicker from "../components/LanguagePicker.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  lang: "es" | "en";
}

const { title, description, lang } = Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      // Script para evitar el "flash" de color al cargar
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      })();
      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>
  </head>
  <body
    class="bg-dot-pattern bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 transition-colors duration-300"
  >
    <header class="max-w-7xl mx-auto flex justify-between items-center p-6">
      <Nav />
      <div class="flex items-center gap-3">
        <LanguagePicker />
        <ThemeToggle />
      </div>
    </header>
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  .bg-dot-pattern {
    position: relative;
  }

  .bg-dot-pattern::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image: radial-gradient(#e5e7eb 1px, transparent 1px);
    background-size: 24px 24px;
    opacity: 0.6;
  }

  .dark .bg-dot-pattern::before {
    background-image: radial-gradient(#1f2937 1px, transparent 1px);
  }
</style>
